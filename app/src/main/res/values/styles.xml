<resources>
    <style name="AppTheme" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">@color/brand_orange</item>
        <item name="android:statusBarColor">@color/brand_orange</item>
        <item name="android:navigationBarColor">@color/brand_orange</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowDisablePreview">true</item>
    </style>

    <style name="SplashTheme" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowBackground">@color/brand_orange</item>
        <item name="android:statusBarColor">@color/brand_orange</item>
        <item name="android:navigationBarColor">@color/brand_orange</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowDisablePreview">true</item>
    </style>
</resources>
